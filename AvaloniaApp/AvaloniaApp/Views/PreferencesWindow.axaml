<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:KafkaLens.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="AvaloniaApp.Views.PreferencesWindow"
        x:DataType="vm:PreferencesViewModel"
        Title="Preferences"
        Width="650" Height="700"
        WindowStartupLocation="CenterOwner">

  <Design.DataContext>
    <vm:PreferencesViewModel/>
  </Design.DataContext>

  <DockPanel Margin="10">
    <StackPanel Orientation="Horizontal" DockPanel.Dock="Bottom" HorizontalAlignment="Right" Spacing="10">
      <Button Command="{Binding SaveCommand}" Content="Save" IsDefault="True"/>
      <Button Command="{Binding CancelCommand}" Content="Cancel" IsCancel="True"/>
    </StackPanel>

    <TabControl SelectedIndex="{Binding SelectedTabIndex}">
      <TabItem Header="General">
        <StackPanel Spacing="10" Margin="10">
          <TextBlock Text="Theme" FontWeight="Bold"/>
          <ComboBox ItemsSource="{Binding Themes}" SelectedItem="{Binding SelectedTheme}" Width="200"/>
        </StackPanel>
      </TabItem>

      <TabItem Header="Kafka">
        <ScrollViewer>
            <StackPanel Spacing="10" Margin="10">
              <TextBlock Text="Timeouts (ms)" FontWeight="Bold"/>

              <TextBlock Text="Query Watermark Timeout"/>
              <TextBox Text="{Binding KafkaConfig.QueryWatermarkTimeoutMs}"/>

              <TextBlock Text="Query Topics Timeout"/>
              <TextBox Text="{Binding KafkaConfig.QueryTopicsTimeoutMs}"/>

              <TextBlock Text="Consume Timeout"/>
              <TextBox Text="{Binding KafkaConfig.ConsumeTimeoutMs}"/>

              <TextBlock Text="Admin Metadata Timeout"/>
              <TextBox Text="{Binding KafkaConfig.AdminMetadataTimeoutMs}"/>

              <TextBlock Text="Limits" FontWeight="Bold" Margin="0,10,0,0"/>

              <TextBlock Text="Fetch Max Bytes"/>
              <TextBox Text="{Binding KafkaConfig.FetchMaxBytes}"/>

              <TextBlock Text="Statistics Interval (ms)"/>
              <TextBox Text="{Binding KafkaConfig.StatisticsIntervalMs}"/>

              <TextBlock Text="Consumer Config" FontWeight="Bold" Margin="0,10,0,0"/>
              <TextBlock Text="Group ID"/>
              <TextBox Text="{Binding KafkaConfig.GroupId}"/>

              <CheckBox IsChecked="{Binding KafkaConfig.EnableAutoOffsetStore}" Content="Enable Auto Offset Store"/>
              <CheckBox IsChecked="{Binding KafkaConfig.EnableAutoCommit}" Content="Enable Auto Commit"/>
            </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Browser">
        <StackPanel Spacing="10" Margin="10">
          <TextBlock Text="Display" FontWeight="Bold"/>

          <TextBlock Text="Font Size"/>
          <TextBox Text="{Binding BrowserConfig.FontSize}"/>

          <TextBlock Text="Available Fetch Counts (comma separated)"/>
          <TextBox Text="{Binding FetchCountsString}"/>
          <TextBlock Text="{Binding FetchCountsError}" Foreground="Red" FontSize="12" Margin="0,2,0,0"/>

          <TextBlock Text="Default Fetch Count"/>
          <ComboBox ItemsSource="{Binding AvailableFetchCounts}" SelectedItem="{Binding SelectedDefaultFetchCount}" Width="200"/>

          <TextBlock Text="Behavior" FontWeight="Bold" Margin="0,10,0,0"/>
          <CheckBox IsChecked="{Binding BrowserConfig.RestoreTabsOnStartup}" Content="Restore open tabs on startup"/>

          <TextBlock Text="Background Connection Check" FontWeight="Bold" Margin="0,10,0,0"/>
          <StackPanel Margin="10,5,0,0" Spacing="5">
              <RadioButton GroupName="ConnectionCheck"
                           IsChecked="{Binding FastConnectionCheck}"
                           Content="Fast (Ping only) - Uses minimal memory, but might falsely show clusters as offline." />
              <RadioButton GroupName="ConnectionCheck"
                           IsChecked="{Binding DeepConnectionCheck}"
                           Content="Deep (Load Topics) - Takes longer and uses more memory, ensures accurate status, opens clusters instantly." />
          </StackPanel>
        </StackPanel>
      </TabItem>

      <TabItem Header="Message Format">
        <DockPanel Margin="10">
          <TextBlock DockPanel.Dock="Top" Text="Enable or disable formatters for message keys and values." Margin="0,0,0,8" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
          <Grid DockPanel.Dock="Top" ColumnDefinitions="*,80,80" Margin="0,0,0,4">
            <TextBlock Grid.Column="0" Text="Formatter" FontWeight="SemiBold" Margin="4,0,0,0"/>
            <TextBlock Grid.Column="1" Text="Keys" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="Values" FontWeight="SemiBold" HorizontalAlignment="Center"/>
          </Grid>
          <Rectangle DockPanel.Dock="Top" Height="1" Fill="{DynamicResource SystemControlForegroundBaseLowBrush}" Margin="0,0,0,4"/>
          <ScrollViewer>
            <ItemsControl ItemsSource="{Binding FormatterSettings}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:FormatterSettingViewModel">
                  <Grid ColumnDefinitions="*,80,80" Margin="0,2,0,2">
                    <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    <CheckBox Grid.Column="1"
                              IsChecked="{Binding IsEnabledForKeys}"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <CheckBox Grid.Column="2"
                              IsChecked="{Binding IsEnabledForValues}"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>
      </TabItem>
    </TabControl>
  </DockPanel>
</Window>