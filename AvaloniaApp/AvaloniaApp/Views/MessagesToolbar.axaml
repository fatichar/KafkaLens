<UserControl x:Class="AvaloniaApp.Views.MessagesToolbar"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:vm="clr-namespace:KafkaLens.ViewModels;assembly=KafkaLens.ViewModels"
	x:DataType="vm:OpenedClusterViewModel">
	<Grid ColumnDefinitions="*, Auto, Auto" Margin="5">
		<TextBox Grid.Column="0" x:Name="FilterBox"
		         VerticalContentAlignment="Center" VerticalAlignment="Center"
		         Text="{Binding CurrentMessages.PositiveFilter}"
		         Watermark="Filter (Ctrl+F)"/>
		<ToggleButton Grid.Column="1" Margin="5,0,0,0" VerticalAlignment="Center"
		              IsChecked="{Binding IsLiveMode, Mode=TwoWay}"
		              ToolTip.Tip="Toggle live streaming (polls every 5 s)">
			<Panel>
				<TextBlock Text="Live" IsVisible="{Binding !IsLiveMode}"/>
				<TextBlock Text="Stop Live" IsVisible="{Binding IsLiveMode}"/>
			</Panel>
		</ToggleButton>
		<Button Grid.Column="2" Content="?" VerticalAlignment="Center" Margin="5,0,0,0"
		        ToolTip.Tip="Filter syntax help">
			<Button.Flyout>
				<Flyout>
					<StackPanel Margin="10" MaxWidth="320">
						<TextBlock FontWeight="Bold" Margin="0,0,0,8">Filter Syntax</TextBlock>
						<TextBlock TextWrapping="Wrap" Margin="0,0,0,10">
							Combine search terms using boolean operators. Multiple words without an operator are treated as OR.
						</TextBlock>
						<Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto, Auto, Auto, Auto">
							<TextBlock Grid.Row="0" Grid.Column="0" FontFamily="Courier New" FontWeight="Bold" Margin="0,0,12,4">&amp;&amp;</TextBlock>
							<TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,4">AND — both terms must match</TextBlock>
							<TextBlock Grid.Row="1" Grid.Column="0" FontFamily="Courier New" FontWeight="Bold" Margin="0,0,12,4">||</TextBlock>
							<TextBlock Grid.Row="1" Grid.Column="1" Margin="0,0,0,4">OR — either term must match</TextBlock>
							<TextBlock Grid.Row="2" Grid.Column="0" FontFamily="Courier New" FontWeight="Bold" Margin="0,0,12,4">!</TextBlock>
							<TextBlock Grid.Row="2" Grid.Column="1" Margin="0,0,0,4">NOT — term must not match</TextBlock>
							<TextBlock Grid.Row="3" Grid.Column="0" FontFamily="Courier New" FontWeight="Bold" Margin="0,0,12,4">( )</TextBlock>
							<TextBlock Grid.Row="3" Grid.Column="1" Margin="0,0,0,4">Grouping</TextBlock>
							<TextBlock Grid.Row="4" Grid.Column="0" FontFamily="Courier New" FontWeight="Bold" Margin="0,0,12,0">"..."</TextBlock>
							<TextBlock Grid.Row="4" Grid.Column="1">Exact phrase match</TextBlock>
						</Grid>
						<TextBlock Margin="0,10,0,4" FontWeight="SemiBold">Examples:</TextBlock>
						<TextBlock FontFamily="Courier New">error &amp;&amp; !debug</TextBlock>
						<TextBlock FontFamily="Courier New">warning || error</TextBlock>
						<TextBlock FontFamily="Courier New">user &amp;&amp; (login || logout)</TextBlock>
						<TextBlock FontFamily="Courier New" Margin="0,4,0,0">word1 word2</TextBlock>
						<TextBlock Margin="0,0,0,4" FontSize="11" Foreground="Gray">matches word1 OR word2</TextBlock>
						<TextBlock FontFamily="Courier New">"word1 word2"</TextBlock>
						<TextBlock FontSize="11" Foreground="Gray">matches the exact phrase</TextBlock>
					</StackPanel>
				</Flyout>
			</Button.Flyout>
		</Button>
	</Grid>
</UserControl>