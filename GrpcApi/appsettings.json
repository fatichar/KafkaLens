{
  "DatabasePath": "cluster_info.json",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http2",
      "HttpsPort": 8888,
      "HttpPort": 8080
    }
  },
  "GrpcFetch": {
    "MaxMessagesPerRequest": 25000,
    "MaxConcurrentFetches": 12,
    "QueueTimeoutMs": 5000,
    "FetchTimeoutMs": 120000
  }
}
